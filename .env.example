# ─── Environment ────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=ondes_db
POSTGRES_USER=ondes_user
POSTGRES_PASSWORD=ondes_password
DATABASE_URL=postgresql://ondes_user:ondes_password@db:5432/ondes_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
