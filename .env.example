# ─── Environment ────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# ─── Database ────────────────────────────────────────────────────────────────
# Docker / production → PostgreSQL:
# DATABASE_URL=postgresql://ondes_user:ondes_password@db:5432/ondes_db
# Local dev → leave DATABASE_URL unset (auto-uses SQLite at api/db.sqlite3)
POSTGRES_DB=ondes_db
POSTGRES_USER=ondes_user
POSTGRES_PASSWORD=ondes_password
DATABASE_URL=postgresql://ondes_user:ondes_password@db:5432/ondes_db

# ─── Redis ───────────────────────────────────────────────────────────────────
# Docker / production → Redis:
# REDIS_URL=redis://redis:6379/0
# Local dev → leave REDIS_URL unset (auto-uses InMemoryChannelLayer)
REDIS_URL=redis://redis:6379/0

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── NGINX Manager ───────────────────────────────────────────────────────────
# Docker Compose : ces valeurs sont injectées automatiquement, ne pas modifier.
# Local dev : laisser vide pour utiliser les chemins /tmp (auto-fallback).
NGINX_VHOSTS_DIR=/nginx-vhosts
LETSENCRYPT_DIR=/etc/letsencrypt

# ─── Server public IP ───────────────────────────────────────────────────────
# IP publique du VPS (utilisée pour la vérification DNS dans l'UI).
# Injectée automatiquement par deploy.sh. Peut être laissée vide si l'API
# peut joindre https://api.ipify.org (fallback automatique).
SERVER_PUBLIC_IP=

# ─── Certbot / Let's Encrypt ─────────────────────────────────────────────────
# Email utilisé par défaut pour les certificats Let's Encrypt.
# Peut également être saisi depuis l'UI (onglet "Domaine & SSL").
CERTBOT_EMAIL=admin@example.com
